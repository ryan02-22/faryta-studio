{
  "compilerOptions": {
    "baseUrl": ".",
    "checkJs": false,
    "ignoreDeprecations": "6.0",
    "jsx": "preserve",
    "paths": {
      "@/*": ["./*"]
    }
  },
  "include": [
    "app/**/*.js",
    "app/**/*.jsx",
    "components/**/*.js",
    "components/**/*.jsx",
    "lib/**/*.js",
    "lib/**/*.jsx",
    "next.config.mjs",
    "postcss.config.js",
    "tailwind.config.js"
  ],
  "exclude": ["node_modules", ".next", "out"]
}
